{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/main.ts",
    "src/App.vue",
    "src/app/**/*.ts",
    "src/app/**/*.vue",
    "src/router/**/*.ts",
    "src/stores/**/*.ts",
    "src/api/**/*.ts",
    "src/layouts/**/*.vue",
    "src/styles/**/*.css",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["src/views", "src/components", "src/features", "node_modules", "dist"]
}
